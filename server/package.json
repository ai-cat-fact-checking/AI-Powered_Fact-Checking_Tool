{
  "name": "fact-check-backend",
  "version": "1.0.0",
  "description": "Express.js backend for AI-powered fact-checking tool",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "test": "node tests/run-all-tests.js",
    "test:api": "node tests/api-test.js",
    "test:auth": "node tests/auth-test.js",
    "test:db": "node tests/database-test.js",
    "test:security": "node tests/security-test.js",
    "lint": "eslint src/",
    "db:test": "node src/utils/dbTest.js",
    "db:migrate": "node src/utils/migrate.js migrate",
