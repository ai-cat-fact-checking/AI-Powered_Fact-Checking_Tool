# Copy this file to server/.env and fill in real values.
#
# Generate strong secrets locally:
#   JWT_SECRET     :  openssl rand -base64 48
#   ENCRYPTION_KEY :  openssl rand -base64 32
#   DB_PASSWORD    :  openssl rand -base64 24

# Database Configuration
DATABASE_URL=postgresql://fact_check_user:CHANGE_ME@localhost:5432/fact_check
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fact_check
DB_USER=fact_check_user
DB_PASSWORD=CHANGE_ME

# Server Configuration
PORT=4999
NODE_ENV=development
API_DOMAIN=localhost:4999
API_URL=http://localhost:4999

# Authentication (replace with output of `openssl rand -base64 ...`)
JWT_SECRET=CHANGE_ME_use_openssl_rand_base64_48
ENCRYPTION_KEY=CHANGE_ME_use_openssl_rand_base64_32

# Google OAuth — create at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=YOUR_GOOGLE_OAUTH_CLIENT_ID.apps.googleusercontent.com

# Optional: server-side Gemini key for /api/analysis/test-* dev endpoints only.
# Leave unset in production. End users provide their own key via the extension.
# GEMINI_API_KEY_DEV=

# CORS Settings — replace YOUR_EXTENSION_ID after loading the unpacked extension
ALLOWED_ORIGINS=chrome-extension://YOUR_EXTENSION_ID,http://localhost:3000,http://localhost:4999

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200
